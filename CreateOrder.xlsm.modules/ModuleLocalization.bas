Private Sub AddSafe(ByVal key As String, ByVal codePointsCsv As String)
    AddTranslation DEFAULT_LANGUAGE_CODE, key, CodePointsCsvToText(codePointsCsv)
End Sub

Private Function CodePointsCsvToText(ByVal codePointsCsv As String) As String
    Dim parts() As String
    Dim i As Long
    Dim token As String
    Dim codePoint As Long
    Dim resultText As String

    If Len(Trim$(codePointsCsv)) = 0 Then Exit Function

    codePointsCsv = Replace$(codePointsCsv, vbCr, "")
    codePointsCsv = Replace$(codePointsCsv, vbLf, "")
    parts = Split(codePointsCsv, ",")
    For i = LBound(parts) To UBound(parts)
        token = Trim$(parts(i))
        If Len(token) = 0 Then GoTo ContinueLoop
        If Not TryParseCodePointToken(token, codePoint) Then GoTo ContinueLoop

        resultText = resultText & ChrW$(codePoint)
ContinueLoop:
    Next i

    CodePointsCsvToText = resultText
End Function

Private Function TryParseCodePointToken(ByVal token As String, ByRef codePoint As Long) As Boolean
    On Error GoTo ParseFailed

    If Not IsNumeric(token) Then Exit Function

    codePoint = CLng(token)
    If codePoint < 0 Or codePoint > 65535 Then Exit Function

    TryParseCodePointToken = True
    Exit Function

ParseFailed:
    codePoint = 0
End Function
