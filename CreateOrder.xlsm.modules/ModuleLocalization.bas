Private Sub LoadLocalizationFromWorkbook()
    On Error GoTo SafeExit

    Dim ws As Worksheet
    Dim lastRow As Long
    Dim lastCol As Long
    Dim rowIndex As Long
    Dim colIndex As Long
    Dim languageCode As String
    Dim translationKey As String
    Dim translationValue As String

    Set ws = Nothing
    On Error Resume Next
    Set ws = ThisWorkbook.Worksheets(LOCALIZATION_SHEET_NAME)
    On Error GoTo SafeExit
    If ws Is Nothing Then Exit Sub

    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
    If lastRow < 2 Or lastCol < 2 Then Exit Sub

    For rowIndex = 2 To lastRow
        translationKey = NormalizeLocalizationKey(CStr(ws.Cells(rowIndex, 1).Value))
        If Len(translationKey) > 0 Then
            For colIndex = 2 To lastCol
                languageCode = NormalizeLanguageCode(CStr(ws.Cells(1, colIndex).Value))
                translationValue = CStr(ws.Cells(rowIndex, colIndex).Value)
                If Len(languageCode) > 0 And Len(translationValue) > 0 Then
                    AddTranslation languageCode, translationKey, translationValue
                End If
            Next colIndex
        End If
    Next rowIndex

SafeExit:
End Sub

Private Function ResolveLocalizedText(ByVal languageCode As String, ByVal localizationKey As String) As String
    Dim cacheKey As String

    cacheKey = BuildLocalizationMapKey(languageCode, localizationKey)
    If localizationCache.Exists(cacheKey) Then
        ResolveLocalizedText = CStr(localizationCache(cacheKey))
    End If
End Function

Private Sub AddTranslation(ByVal languageCode As String, ByVal key As String, ByVal value As String)
    Dim normalizedLanguage As String
    Dim normalizedKey As String

    normalizedLanguage = NormalizeLanguageCode(languageCode)
    normalizedKey = NormalizeLocalizationKey(key)

    If Len(normalizedLanguage) = 0 Or Len(normalizedKey) = 0 Then Exit Sub
    If Len(Trim$(value)) > 0 And IsLikelyBrokenLocalizationText(value) Then Exit Sub

    localizationCache(BuildLocalizationMapKey(normalizedLanguage, normalizedKey)) = value
End Sub

Private Function NormalizeLocalizationKey(ByVal key As String) As String
    NormalizeLocalizationKey = LCase$(Trim$(key))
End Function

Private Function NormalizeLanguageCode(ByVal languageCode As String) As String
    NormalizeLanguageCode = LCase$(Trim$(languageCode))
End Function

Private Function BuildLocalizationMapKey(ByVal languageCode As String, ByVal key As String) As String
    BuildLocalizationMapKey = NormalizeLanguageCode(languageCode) & "|" & NormalizeLocalizationKey(key)
End Function

