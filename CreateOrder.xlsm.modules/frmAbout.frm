    End If
    
    If modActivation.TryActivateLicenseCodeDetailed(key, activationMessage) Then
        MsgBox activationMessage, vbInformation, t("license.caption.activation", "?????????")
        UpdateLicenseStatusUI
        txtActivationCode.Text = ""
